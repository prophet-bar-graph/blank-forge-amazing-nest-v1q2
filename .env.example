# Lyzr API Key (required for agent calls)
LYZR_API_KEY=your-lyzr-api-key-here
DATABASE_URL=mongodb://127.0.0.1:27017
APP_JWT_SECRET=randomsecret1234isbetterthanpassword

# Optional: Agent ID (can also be set per-component)
AGENT_ID=your-agent-id-here

# === Brand access control (added 2026-06-10) ===

# Comma-separated list of admin emails. Admins can approve/deny unlock requests
# and bypass the lock check on their own brand profile saves.
ADMIN_EMAILS=ddowling@prophet.com

# (Optional, dev-only) Fallback email when Keycloak SSO is off and no ?as= URL
# param is set. Tier 4 in the resolution chain — used only if nothing else
# provides an identity. Should not be set in production.
# NEXT_PUBLIC_DEV_USER_EMAIL=local-dev@example.com
