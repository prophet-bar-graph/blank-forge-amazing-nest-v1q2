# ======================================================================
# MAIA Writing Studio — environment variables
# Copy this file to .env.local and fill in the values.
# Only the keys the app actually reads are listed here.
# ======================================================================

# --- Lyzr API / User -------------------------------------------------
# API key for all MAIA Studio / Lyzr agent calls (required).
LYZR_API_KEY=
# Default user_id sent with agent calls (your Prophet email).
LYZR_USER_ID=

# --- Lyzr service URLs ----------------------------------------------
LYZR_AGENT_BASE_URL=https://agent.maia.prophet.com
LYZR_RAG_BASE_URL=https://rag.maia.prophet.com
# Optional — defaults to https://scheduler.studio.lyzr.ai if unset.
# LYZR_SCHEDULER_BASE_URL=

# --- Architect backend ----------------------------------------------
ARCHITECT_BACKEND_URL=https://api.prophet.architect.new
# Uncomment the following to enable SSO
# ARCHITECT_TENANT_ID=prophet
# TENANT_ID=prophet

# --- Database --------------------------------------------------------
# Local dev points at a local MongoDB (see README, step 3).
DATABASE_URL=mongodb://127.0.0.1:27017/writing-studio
APP_JWT_SECRET=randomsecret1234isbetterthanpassword

# --- Public (client-exposed NEXT_PUBLIC_*) --------------------------
NEXT_PUBLIC_LYZR_AGENT_BASE_URL=https://agent.maia.prophet.com
# Optional default agent id exposed to the client.
# NEXT_PUBLIC_AGENT_ID=

# --- Brand access control -------------------------------------------
# Comma-separated list of admin emails. Admins can approve/deny unlock
# requests and bypass the lock check on their own brand profile saves.
ADMIN_EMAILS=

# --- Dev-only --------------------------------------------------------
# Set to "true" to bypass SSO config (sandbox/dev mode).
# SANDBOX_MODE=
# Fallback email when Keycloak SSO is off and no ?as= URL param is set.
# Tier 4 in the identity resolution chain. Do not set in production.
# NEXT_PUBLIC_DEV_USER_EMAIL=
